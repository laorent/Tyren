# Gemini API Key (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Web Access Password (Required)
WEB_ACCESS_PASSWORD=your_secure_password_here

# Gemini Model Name (Optional, defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Model used for "Thinking Mode" (Optional, defaults to gemini-2.0-flash-thinking-exp-01-21)
GEMINI_THINKING_MODEL=gemini-2.0-flash-thinking-exp-01-21
